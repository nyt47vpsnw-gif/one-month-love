<!doctype html>
<html lang="zh-Hant">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>獻給我最特別的人——廖尹瑄 ❤️</title>
  <style>
    :root{
      --bg1:#ffffff;
      --bg2:#f7f2f4;
      --bg3:#efe6ea;
      --text:#2b2b2b;
      --muted:#6d6d6d;
      --line:rgba(0,0,0,.08);
      --accent:#e66a88;
      --accent2:#c96f85;
      --shadow:0 20px 60px rgba(0,0,0,.10);
      --radius:28px;
    }
    *{box-sizing:border-box}
    html,body{height:100%}
    body{
      margin:0;
      font-family:-apple-system,BlinkMacSystemFont,"Segoe UI","PingFang TC","Noto Sans TC",sans-serif;
      color:var(--text);
      background:
        radial-gradient(circle at top, rgba(230,106,136,.10), transparent 32%),
        linear-gradient(180deg, var(--bg1), var(--bg2) 55%, var(--bg3));
      overflow-x:hidden;
    }
    .wrap{
      min-height:100%;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:22px;
      position:relative;
    }
    .card{
      width:min(980px, 100%);
      background:rgba(255,255,255,.72);
      border:1px solid var(--line);
      border-radius:36px;
      box-shadow:var(--shadow);
      backdrop-filter:blur(18px);
      overflow:hidden;
      position:relative;
    }
    .hero{
      padding:42px 22px 28px;
      text-align:center;
      position:relative;
    }
    .badge{
      display:inline-flex;
      gap:8px;
      align-items:center;
      padding:10px 14px;
      border-radius:999px;
      background:rgba(230,106,136,.10);
      color:var(--accent2);
      font-size:14px;
      letter-spacing:.5px;
      margin-bottom:14px;
    }
    h1{
      margin:0;
      font-size:clamp(30px, 5vw, 54px);
      line-height:1.1;
      letter-spacing:.2px;
    }
    .sub{
      margin:14px 0 0;
      color:var(--muted);
      font-size:16px;
    }
    .envelope{
      width:min(360px, 78vw);
      margin:30px auto 6px;
      cursor:pointer;
      user-select:none;
      perspective:1000px;
    }
    .env{
      position:relative;
      height:220px;
      border-radius:28px;
      background:linear-gradient(180deg, #fff, #f7eef1);
      box-shadow:0 18px 45px rgba(0,0,0,.12);
      border:1px solid rgba(0,0,0,.06);
      transform-style:preserve-3d;
      transition:transform .8s ease;
    }
    .env::before,
    .env::after{
      content:"";
      position:absolute;
      inset:0;
      border-radius:28px;
      pointer-events:none;
    }
    .env::before{
      background:
        linear-gradient(135deg, transparent 49.5%, #e8c9d3 50%, transparent 50.5%),
        linear-gradient(225deg, transparent 49.5%, #e8c9d3 50%, transparent 50.5%);
      background-size:50% 100%;
      background-repeat:no-repeat;
      background-position:left, right;
      clip-path:polygon(0 0, 100% 0, 100% 100%, 0 100%);
      opacity:.9;
    }
    .flap{
      position:absolute;
      left:0; right:0; top:0;
      height:50%;
      border-radius:28px 28px 18px 18px;
      background:linear-gradient(180deg, #fff, #f2dfe6);
      clip-path:polygon(0 0, 100% 0, 50% 100%);
      transform-origin:top;
      transform:rotateX(0deg);
      transition:transform .9s ease;
      border-bottom:1px solid rgba(0,0,0,.04);
      z-index:2;
    }
    .letter{
      position:absolute;
      inset:22px 18px 18px;
      border-radius:20px;
      background:rgba(255,255,255,.95);
      border:1px solid rgba(0,0,0,.05);
      transform:translateY(42px);
      opacity:0;
      transition:all .9s ease;
      z-index:1;
      padding:18px 18px 16px;
      overflow:hidden;
    }
    .letter h2{
      margin:0 0 10px;
      font-size:18px;
      color:var(--accent2);
    }
    .letter p{
      margin:0;
      line-height:1.9;
      font-size:15px;
      white-space:pre-line;
    }
    .envelope.open .flap{transform:rotateX(180deg)}
    .envelope.open .letter{transform:translateY(-6px); opacity:1}
    .tap{
      margin-top:12px;
      font-size:14px;
      color:var(--muted);
    }
    .sections{
      display:none;
      padding:10px 22px 26px;
      gap:18px;
    }
    .sections.show{display:grid}
    .panel{
      border:1px solid var(--line);
      background:rgba(255,255,255,.78);
      border-radius:var(--radius);
      padding:22px;
      box-shadow:0 8px 28px rgba(0,0,0,.05);
    }
    .panel h3{
      margin:0 0 10px;
      font-size:22px;
    }
    .panel .muted{color:var(--muted); margin:0}
    .countdown{
      display:grid;
      grid-template-columns:repeat(4, minmax(0,1fr));
      gap:10px;
      margin-top:18px;
    }
    .box{
      text-align:center;
      padding:16px 10px;
      border-radius:22px;
      background:linear-gradient(180deg, #fff, #faf7f8);
      border:1px solid rgba(0,0,0,.06);
    }
    .num{font-size:clamp(24px,4vw,40px); font-weight:700; color:var(--accent2)}
    .lab{font-size:13px; color:var(--muted); margin-top:4px}
    .gallery{
      display:grid;
      grid-template-columns:repeat(5, minmax(0,1fr));
      gap:10px;
      margin-top:16px;
    }
    .photo{
      border-radius:18px;
      overflow:hidden;
      position:relative;
      aspect-ratio:3/4;
      background:linear-gradient(135deg, #f6e7ec, #fff);
      border:1px solid rgba(0,0,0,.06);
    }
    .photo img{
      width:100%;
      height:100%;
      object-fit:cover;
      display:block;
    }
    .placeholder{
      position:absolute;
      inset:0;
      display:none;
      align-items:center;
      justify-content:center;
      text-align:center;
      padding:12px;
      color:#7a6770;
      font-size:14px;
      background:
        radial-gradient(circle at top, rgba(230,106,136,.12), transparent 60%),
        linear-gradient(180deg, #fff, #f7eef1);
    }
    .photo img[onerror] + .placeholder{display:flex}
    .footer-quote{
      text-align:center;
      padding:24px 22px 34px;
      color:var(--accent2);
      font-size:18px;
      line-height:1.8;
    }
    .btnrow{
      display:flex;
      gap:12px;
      justify-content:center;
      flex-wrap:wrap;
      margin-top:18px;
    }
    button{
      border:none;
      border-radius:999px;
      padding:14px 18px;
      font-size:15px;
      cursor:pointer;
      box-shadow:0 10px 24px rgba(0,0,0,.08);
    }
    .primary{
      background:linear-gradient(135deg, var(--accent), #f08aa2);
      color:#fff;
    }
    .ghost{
      background:#fff;
      color:var(--accent2);
      border:1px solid rgba(0,0,0,.08);
    }
    canvas#fireworks{
      position:fixed;
      inset:0;
      pointer-events:none;
      z-index:99;
    }

    @media (max-width: 860px){
      .gallery{grid-template-columns:repeat(2, minmax(0,1fr))}
      .countdown{grid-template-columns:repeat(2, minmax(0,1fr))}
      .hero{padding:34px 18px 24px}
      .sections{padding:8px 18px 22px}
    }
  </style>
</head>
<body>
<canvas id="fireworks"></canvas>

<div class="wrap">
  <div class="card">
    <div class="hero">
      <div class="badge">❤️ 獻給我最特別的人 —— 廖尹瑄</div>
      <h1>From 王耀勝</h1>
      <p class="sub">一封打開後，會出現我們回憶的小情書。</p>

      <div class="envelope" id="envelope" aria-label="點擊信封開始">
        <div class="env">
          <div class="flap"></div>
          <div class="letter">
            <h2>親愛的尹瑄：</h2>
            <p id="typeText"></p>
          </div>
        </div>
      </div>
      <div class="tap">點一下信封開始</div>

      <div class="btnrow">
        <button class="primary" id="openBtn">❤️ 打開信封</button>
        <button class="ghost" id="musicBtn">🎵 音樂提示</button>
      </div>
    </div>

    <div class="sections" id="sections">
      <div class="panel">
        <h3>⏳ 我們已經一起</h3>
        <p class="muted">從 2026/05/31 開始，時間一直在往前走。</p>
        <div class="countdown">
          <div class="box"><div class="num" id="days">0</div><div class="lab">天</div></div>
          <div class="box"><div class="num" id="hours">0</div><div class="lab">小時</div></div>
          <div class="box"><div class="num" id="mins">0</div><div class="lab">分鐘</div></div>
          <div class="box"><div class="num" id="secs">0</div><div class="lab">秒</div></div>
        </div>
      </div>

      <div class="panel">
        <h3>📸 我們的回憶</h3>
        <p class="muted">把照片上傳成 photo1.jpg ～ photo5.jpg 後，這裡就會顯示。</p>
        <div class="gallery">
          <div class="photo">
            <img src="images/photo1.jpg" alt="照片1" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
            <div class="placeholder">照片 1<br>上傳後會顯示</div>
          </div>
          <div class="photo">
            <img src="images/photo2.jpg" alt="照片2" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
            <div class="placeholder">照片 2<br>上傳後會顯示</div>
          </div>
          <div class="photo">
            <img src="images/photo3.jpg" alt="照片3" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
            <div class="placeholder">照片 3<br>上傳後會顯示</div>
          </div>
          <div class="photo">
            <img src="images/photo4.jpg" alt="照片4" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
            <div class="placeholder">照片 4<br>上傳後會顯示</div>
          </div>
          <div class="photo">
            <img src="images/photo5.jpg" alt="照片5" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
            <div class="placeholder">照片 5<br>上傳後會顯示</div>
          </div>
        </div>
      </div>

      <div class="panel">
        <h3>💌 最後想對妳說</h3>
        <p id="finalText" style="font-size:16px;line-height:1.9;margin:0;white-space:pre-line;"></p>
        <div class="btnrow">
          <button class="primary" id="fireBtn">🎆 點我放煙火</button>
        </div>
      </div>
    </div>

    <div class="footer-quote">
      廖尹瑄 × 王耀勝<br>
      <strong>我會一直一直愛妳。❤️</strong>
    </div>
  </div>
</div>

<script>
  const message = `一個月說長不長，但因為有妳，每一天都變得很特別。

謝謝妳陪伴我、也謝謝妳讓我知道，
原來喜歡一個人，可以這麼幸福。

我想把之後的每一個月，都和妳一起好好珍惜。

一個月快樂，尹瑄。❤️`;

  const finalMessage = `謝謝妳成為我生命中特別的人。

廖尹瑄，我會一直一直愛妳。❤️

—— 王耀勝`;

  const typeText = document.getElementById('typeText');
  const finalText = document.getElementById('finalText');
  const envelope = document.getElementById('envelope');
  const sections = document.getElementById('sections');
  const openBtn = document.getElementById('openBtn');
  const musicBtn = document.getElementById('musicBtn');
  const fireBtn = document.getElementById('fireBtn');

  let opened = false;
  let i = 0;

  function typeWriter(){
    if(i <= message.length){
      typeText.textContent = message.slice(0, i++);
      setTimeout(typeWriter, 22);
    }else{
      finalText.textContent = finalMessage;
    }
  }

  function openEnvelope(){
    if(opened) return;
    opened = true;
    envelope.classList.add('open');
    sections.classList.add('show');
    typeWriter();
    setTimeout(()=>window.scrollTo({top:document.body.scrollHeight/3, behavior:'smooth'}), 700);
  }

  envelope.addEventListener('click', openEnvelope);
  openBtn.addEventListener('click', openEnvelope);

  musicBtn.addEventListener('click', ()=>{
    alert('之後把背景音樂放到 music/song.mp3，就可以在這裡加入播放功能。');
  });

  // Countdown: since 2026/05/31
  const start = new Date('2026-05-31T00:00:00');
  const daysEl = document.getElementById('days');
  const hoursEl = document.getElementById('hours');
  const minsEl = document.getElementById('mins');
  const secsEl = document.getElementById('secs');

  function updateCountdown(){
    const now = new Date();
    let diff = Math.max(0, now - start);

    const days = Math.floor(diff / (1000*60*60*24));
    diff -= days * (1000*60*60*24);
    const hours = Math.floor(diff / (1000*60*60));
    diff -= hours * (1000*60*60);
    const mins = Math.floor(diff / (1000*60));
    diff -= mins * (1000*60);
    const secs = Math.floor(diff / 1000);

    daysEl.textContent = days;
    hoursEl.textContent = hours;
    minsEl.textContent = mins;
    secsEl.textContent = secs;
  }
  updateCountdown();
  setInterval(updateCountdown, 1000);

  // Simple fireworks
  const canvas = document.getElementById('fireworks');
  const ctx = canvas.getContext('2d');
  let w,h, particles=[];
  function resize(){
    w = canvas.width = window.innerWidth * devicePixelRatio;
    h = canvas.height = window.innerHeight * devicePixelRatio;
    canvas.style.width = window.innerWidth + 'px';
    canvas.style.height = window.innerHeight + 'px';
    ctx.setTransform(devicePixelRatio,0,0,devicePixelRatio,0,0);
  }
  window.addEventListener('resize', resize);
  resize();

  function burst(x,y){
    const colors = ['#ff7aa2','#ffb6c1','#ffd1dc','#ffffff','#f59ab0'];
    for(let k=0;k<42;k++){
      const a = Math.random() * Math.PI * 2;
      const s = 2 + Math.random() * 5;
      particles.push({
        x, y,
        vx: Math.cos(a) * s,
        vy: Math.sin(a) * s,
        life: 90 + Math.random()*30,
        color: colors[(Math.random()*colors.length)|0],
        r: 1.5 + Math.random()*2.5
      });
    }
  }

  function loop(){
    ctx.clearRect(0,0,window.innerWidth,window.innerHeight);
    particles = particles.filter(p => p.life > 0);
    for(const p of particles){
      p.x += p.vx;
      p.y += p.vy;
      p.vy += 0.04;
      p.life -= 1;
      ctx.globalAlpha = Math.max(0, p.life / 120);
      ctx.fillStyle = p.color;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI*2);
      ctx.fill();
    }
    ctx.globalAlpha = 1;
    requestAnimationFrame(loop);
  }
  loop();

  fireBtn.addEventListener('click', ()=>{
    for(let n=0;n<6;n++){
      setTimeout(()=>{
        burst(
          window.innerWidth * (0.2 + Math.random()*0.6),
          window.innerHeight * (0.15 + Math.random()*0.35)
        );
      }, n*180);
    }
  });

  // automatic tiny sparkles after open
  setTimeout(()=>{ if(opened) burst(window.innerWidth*0.5, window.innerHeight*0.22); }, 2000);
</script>
</body>
</html>
